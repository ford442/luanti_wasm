{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 12
  },
  "configurePresets": [
    {
      "name": "Debug",
      "displayName": "Debug",
      "description": "Debug preset with debug symbols and no optimizations",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "displayName": "Release",
      "description": "Release preset with optimizations and no debug symbols",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "description": "Release with debug symbols",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "MinSizeRel",
      "displayName": "MinSizeRel",
      "description": "Release with minimal code size",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "Emscripten",
      "displayName": "Emscripten (WebAssembly)",
      "description": "Client-only WASM build via Emscripten. Run: emcmake cmake --preset Emscripten -B build-wasm",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "binaryDir": "${sourceDir}/build-wasm",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_CLIENT": "TRUE",
        "BUILD_SERVER": "FALSE",
        "BUILD_UNITTESTS": "FALSE",
        "BUILD_BENCHMARKS": "FALSE",
        "ENABLE_SOUND": "FALSE",
        "ENABLE_CURL": "FALSE",
        "ENABLE_GETTEXT": "FALSE",
        "ENABLE_CURSES": "FALSE",
        "ENABLE_POSTGRESQL": "FALSE",
        "ENABLE_LEVELDB": "FALSE",
        "ENABLE_REDIS": "FALSE",
        "ENABLE_PROMETHEUS": "FALSE",
        "ENABLE_SPATIAL": "FALSE",
        "ENABLE_OPENSSL": "FALSE",
        "ENABLE_GLES2": "TRUE",
        "ENABLE_OPENGL": "FALSE",
        "ENABLE_OPENGL3": "FALSE",
        "RUN_IN_PLACE": "TRUE"
      }
    }
  ]
}
